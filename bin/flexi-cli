#!/usr/bin/env php
<?php

if (file_exists(__DIR__.'/../vendor/autoload.php')) {
    require __DIR__.'/../vendor/autoload.php';
} elseif (file_exists(__DIR__.'/../../../autoload.php')) {
    require __DIR__.'/../../../autoload.php';
} else {
    fwrite(STDERR, "Could not find Composer autoloader.\n");
    exit(1);
}

use FlexiCli\Command\AddCommand;
use FlexiCli\Command\BuildCommand;
use FlexiCli\Command\CleanFluxCommand;
use FlexiCli\Command\FixIcons;
use FlexiCli\Command\InitCommand;
use FlexiCli\Command\ValidateCommand;
use Symfony\Component\Console\Application;

$application = new Application('Flexi-CLI', '1.0.0');

$application->addCommand(new InitCommand());
$application->addCommand(new AddCommand());
$application->addCommand(new BuildCommand());
$application->addCommand(new ValidateCommand());
$application->addCommand(new CleanFluxCommand());
$application->addCommand(new FixIcons());

$application->run();
