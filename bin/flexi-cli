#!/usr/bin/env php
<?php

if (file_exists(__DIR__.'/../vendor/autoload.php')) {
    require __DIR__.'/../vendor/autoload.php';
} elseif (file_exists(__DIR__.'/../../../autoload.php')) {
    require __DIR__.'/../../../autoload.php';
} else {
    fwrite(STDERR, "Could not find Composer autoloader.\n");
    exit(1);
}

// Monorepo fallback: allow running packages/cli directly even when FlexiCore is not
// present in this package's vendor autoload map.
if (!class_exists(\FlexiCore\Core\Constants::class)) {
    $coreRoot = realpath(__DIR__ . '/../../core/src');
    if ($coreRoot !== false) {
        spl_autoload_register(static function (string $class) use ($coreRoot): void {
            $prefix = 'FlexiCore\\';
            if (!str_starts_with($class, $prefix)) {
                return;
            }

            $relative = str_replace('\\', '/', substr($class, strlen($prefix))) . '.php';
            $file = $coreRoot . '/' . $relative;
            if (file_exists($file)) {
                require $file;
            }
        });
    }
}

use FlexiCli\Command\AddCommand;
use FlexiCli\Command\BuildCommand;
use FlexiCli\Command\FixIcons;
use FlexiCli\Command\InitCommand;
use FlexiCli\Command\ValidateCommand;
use Symfony\Component\Console\Application;

$application = new Application('Flexi-CLI', '1.0.0');

$application->addCommand(new InitCommand());
$application->addCommand(new AddCommand());
$application->addCommand(new BuildCommand());
$application->addCommand(new ValidateCommand());
$application->addCommand(new FixIcons());

$application->run();
