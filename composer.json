{
    "name": "unoforge/flexi-cli",
    "description": "CLI wrapper for the full Flexi PHP workflows",
    "version": "1.1.2",
    "type": "cli",
    "require": {
        "symfony/console": "^7.3 || ^8.0",
        "symfony/yaml": "^7.3 || ^8.0",
        "laravel/prompts": "^0.3.10",
        "unoforge/flexi-core": "^1.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../core",
            "options": {
                "symlink": true
            }
        }
    ],
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "FlexiCli\\": "src/"
        }
    },
    "bin": ["bin/flexi-cli"],
    "authors": [
        {
            "name": "Johnkat Mj",
            "email": "johnkatembue4@gmail.com"
        }
    ]
}
